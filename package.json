{
  "name": "grain-monorepo",
  "version": "1.2.1",
  "description": "Universal interaction layer for AI interfaces",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "homepage": "https://sir-ad.github.io/grain/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sir-ad/grain.git"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "eslint .",
    "check": "pnpm lint && pnpm build && pnpm test",
    "release": "pnpm check && changeset version"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.1",
    "globals": "^15.15.0",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1",
  "keywords": [
    "ai",
    "ui",
    "interface",
    "primitives",
    "components",
    "chat",
    "g-lang",
    "@grain.sh/core"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sir-ad/grain/issues"
  }
}
