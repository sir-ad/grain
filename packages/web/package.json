{
  "name": "@grain.sh/web",
  "version": "1.3.2",
  "description": "Web adapter for Grain - Universal AI interaction layer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@grain.sh/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "@grain.sh/core",
    "g-lang",
    "web",
    "adapter",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sir-ad/grain.git"
  },
  "devDependencies": {
    "happy-dom": "^20.0.8",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  }
}
