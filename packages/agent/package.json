{
    "name": "@grain.sh/agent",
    "version": "1.3.0",
    "description": "Agent-to-agent communication protocol for G-Lang",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch"
    },
    "dependencies": {
        "@grain.sh/core": "workspace:*"
    },
    "devDependencies": {
        "tsup": "^8.3.0",
        "typescript": "^5.6.2"
    }
}
