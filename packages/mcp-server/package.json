{
  "name": "@grain.sh/mcp-server",
  "version": "1.3.2",
  "description": "MCP Server for Grain - Universal AI interaction layer",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "grain-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@grain.sh/mcp": "workspace:*",
    "@grain.sh/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "@grain.sh/core",
    "g-lang",
    "mcp",
    "server"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sir-ad/grain.git"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
