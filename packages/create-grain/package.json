{
    "name": "create-grain-app",
    "version": "1.3.0",
    "description": "Scaffolding tool for Grain AI applications",
    "type": "module",
    "bin": {
        "create-grain": "dist/index.js",
        "create-grain-app": "dist/index.js"
    },
    "files": [
        "dist",
        "templates"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "commander": "^11.1.0",
        "inquirer": "^9.2.12",
        "chalk": "^5.3.0",
        "fs-extra": "^11.2.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/inquirer": "^9.0.7",
        "@types/fs-extra": "^11.0.4",
        "tsup": "^8.0.1",
        "typescript": "^5.3.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "@grain.sh/core",
        "create-grain",
        "scaffold",
        "ai",
        "g-lang"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/sir-ad/grain.git"
    }
