{
  "name": "@grain.sh/mcp",
  "version": "1.3.2",
  "description": "MCP adapter for Grain - Universal AI interaction layer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@grain.sh/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "@grain.sh/core",
    "g-lang",
    "mcp",
    "model-context-protocol",
    "adapter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sir-ad/grain.git"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
