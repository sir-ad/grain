{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs:build": {
      "dependsOn": ["@grain.sh/core:build", "@grain.sh/web:build"],
      "outputs": ["docs/.vitepress/dist/**"]
    }
  }
}
